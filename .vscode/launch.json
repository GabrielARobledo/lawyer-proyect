{
  "version": "0.2.0",
  "configurations": [
    {
    "type": "node",
    "request": "launch",
    "name": "Next.js API Debug",
    "runtimeExecutable": "npx",
    "runtimeArgs": ["next", "dev", "--inspect-brk"],
    "port": 9229,
    "cwd": "${workspaceFolder}",
    "console": "integratedTerminal",
    "skipFiles": ["<node_internals>/**"]
    }
  ]
}